<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/card_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- COLOR INDICATOR -->
        <View
            android:id="@+id/expiry_indicator"
            android:layout_width="6dp"
            android:layout_height="60dp"
            android:background="#52B788"
            android:layout_marginEnd="16dp" />

        <!-- PRODUCT INFO -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_product_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Whole Milk"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark" />

            <TextView
                android:id="@+id/tv_barcode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Barcode: 1234567890"
                android:textSize="12sp"
                android:textColor="@color/text_grey"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- EXPIRY BADGE -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_expiry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3 days left"
            android:textColor="@color/white"
            app:chipBackgroundColor="@color/safe_green"
            app:chipCornerRadius="8dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>